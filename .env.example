# FuzzGuard Deployment Configuration
# Copy to .env and adjust values

# Encryption key for API keys at rest (Fernet 32-byte base64)
FUZZGUARD_ENCRYPTION_KEY=

# Database URL (default: sqlite:///data/fuzzguard.db)
# For PostgreSQL: postgresql://user:password@host:5432/fuzzguard
FUZZGUARD_DATABASE_URL=sqlite:///data/fuzzguard.db

# Scheduler
FUZZGUARD_SCHEDULER_ENABLED=true
FUZZGUARD_SCHEDULER_CHECK_INTERVAL=30

# API Provider Keys (alternative to setting via UI)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-...
# GOOGLE_API_KEY=...
